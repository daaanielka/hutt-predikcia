# =============================================================================
# ŠABLÓNA: .streamlit/secrets.toml
# =============================================================================
# Tento súbor NIKDY nepridávaj do GitHubu!
# Skopíruj jeho obsah do Streamlit Cloud → App → Settings → Secrets
# =============================================================================

# ID tvojej Google Tabuľky (z URL: docs.google.com/spreadsheets/d/TOTO_JE_ID/edit)
gsheet_id = "SEM_VLOZ_ID_TVOJEJ_GOOGLE_TABULKY"

# Service Account prihlasovacie údaje (z JSON súboru stiahnutého z Google Cloud)
[gcp_service_account]
type                        = "service_account"
project_id                  = "tvoj-projekt-id"
private_key_id              = "abc123..."
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "hutt-app@tvoj-projekt.iam.gserviceaccount.com"
client_id                   = "123456789"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/hutt-app%40tvoj-projekt.iam.gserviceaccount.com"
